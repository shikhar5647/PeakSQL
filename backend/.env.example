# ---- LLM provider: mock | gemini | vllm | openai ----
# "mock" = deterministic heuristics, no API key needed (great for development/UI work)
PEAKSQL_LLM_PROVIDER=mock

# Gemini via its OpenAI-compatible endpoint:
# PEAKSQL_LLM_PROVIDER=gemini
# PEAKSQL_LLM_MODEL=gemini-3-pro
# PEAKSQL_LLM_API_KEY=your-google-ai-studio-key
# PEAKSQL_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Open-source model served by vLLM (uses guided JSON decoding):
# PEAKSQL_LLM_PROVIDER=vllm
# PEAKSQL_LLM_MODEL=Qwen/Qwen3-32B
# PEAKSQL_LLM_BASE_URL=http://localhost:8001/v1
# PEAKSQL_LLM_API_KEY=EMPTY

# ---- Neo4j (optional — pipeline runs fully without it) ----
# PEAKSQL_NEO4J_URI=bolt://localhost:7687
# PEAKSQL_NEO4J_USER=neo4j
# PEAKSQL_NEO4J_PASSWORD=password
